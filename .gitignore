.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
htmlcov/
.coverage
smcr_staff_ai.db
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/local_context/*
!data/local_context/.gitkeep
# Explicitly block generated session output and any local context subdirs
outputs/
data/local_context/*/

# User project workspaces — scenario files, exercise products, AI-generated documents.
projects/*
!projects/.gitkeep

# Local-only user notes, generated outputs, and scratch work.
docs/offline_notes.md
docs/deep_research/*_pull.md
docs/scenarios/
docs/sources/civil_affairs.md
scripts/scratch_*/

# Auto-generated improvement tracking files — local only, never commit to public repo.
# These may contain session notes or testing context not suitable for public GitHub.
FINDINGS_HANDOFF.md
USAGE_NOTES.md
docs/IMPROVEMENT_PLAN_*.md
docs/UPSTREAM_INSIGHTS_*.md

# Claude Code local config — machine-specific paths, session state, skills.
# Skills are AI-tool-specific; portable knowledge lives in docs/ instead.
.claude/settings.local.json
.claude/todos.json
.claude/skills/
