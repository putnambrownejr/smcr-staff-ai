APP_NAME="SMCR Staff AI"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
VECTOR_STORE_BACKEND="local-stub"
LOCAL_API_KEY=""
MAX_UPLOAD_BYTES="50000000"
PUBLIC_SOURCE_ONLY="true"

# Leave the paths below unset to use the default user-scoped storage home outside the repo.
# Windows default: %LOCALAPPDATA%\smcr-staff-ai
# Preferred override: move the entire local state root.
# SMCR_STAFF_AI_HOME="C:/Users/<you>/AppData/Local/smcr-staff-ai"

# Advanced overrides: set individual stores only when you need split storage.
# DATABASE_URL="sqlite:///C:/Users/<you>/AppData/Local/smcr-staff-ai/smcr_staff_ai.db"
# LOCAL_CONTEXT_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context"
# SESSION_HANDOFF_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/session_handoffs"
# PRODUCT_TEMPLATE_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/product_templates"
# TRAVEL_CASE_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/travel_cases"
# BATTLE_RHYTHM_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/battle_rhythm"
# READING_STATE_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/reading_state"
# READING_CATALOG_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/reading_catalog"
# MARADMIN_FEED_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/maradmin_feed"
# NAVY_MESSAGE_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/navy_messages"
# DOD_WATCH_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/dod_watch"
# CUSTOM_WATCH_FEED_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/custom_watch_feeds"
# SECTION_MEMORY_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/section_memory"
# HISTORY_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/history"
# ACTIVE_USER_CONTEXT_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/active_user_context"
# ACTIONS_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/actions"
# DOCUMENT_UPDATES_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/document_updates"
# DRILL_PLANS_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/drill_plans"
# OPPORTUNITIES_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/opportunities"
# SOURCE_STATES_STORAGE_DIR="C:/Users/<you>/AppData/Local/smcr-staff-ai/local_context/source_states"
